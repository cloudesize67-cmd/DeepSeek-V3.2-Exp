{
    "name": "wpg/wordpress-policy-gate",
    "description": "WordPress plugin: policy gate for AI-agent bulk actions with Merkle-tree audit log",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "WPG\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPG\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "config": {
        "optimize-autoloader": true
    }
}
